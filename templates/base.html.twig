<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Welcome!
			{% endblock %}
		</title>
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
		{{ encore_entry_link_tags('app') }}
	</head>
	<body>
		{% block javascripts %}
			{{ encore_entry_script_tags('app') }}
			{% block importmap %}
				{{ importmap('app') }}
			{% endblock %}
		{% endblock %}
	</body>
</html><body>
<section class="toTop">
	<button onclick="topFunction()" id="myBtn" title="Go to top">↑</button>
</section>
<header>
	<div class="container">
		<a href={{path('app_accueil')}} class="logo">
			<img src={{asset('images/logo.png')}} alt="">
		</a>
		<div class="menu">
			<div class="menu-line"></div>
			<div class="menu-line"></div>
			<div class="menu-line"></div>
		</div>
		<nav class="links-menu">
			<ul>
				<li>
					<a href={{path('app_accueil')}}>Accueil</a>
				</li>
				<li>
					<a href={{path('beatmap_search')}}>Beatmaps</a>
				</li>
				{% if app.user %}
					<li>
						<a href={{path('app_logout')}}>Deconnexion</a>
					</li>
					<li>
						<a href="{{ path('app_profile', { id: app.user.id }) }}" class="profil_btn">
							{% if app.user and app.user.imageName %}
								<img src="{{ vich_uploader_asset(app.user, 'imageFile') }}" alt="Avatar">
							{% else %}
								<img src="{{ asset('images/default.png') }}" alt="Avatar par défaut">
							{% endif %}
						</a>
					</li>
				{% else %}
					<li>
						<a href="{{ path('app_login') }}">Connexion</a>
					</li>
					<li>
						<a href="{{ path('app_register') }}">S'inscrire</a>
					</li>
				{% endif %}
			</ul>

		</nav>

	</div>
</header>
{% block body %}{% endblock %}</body><footer>
<div class="container">
	<div class="footer-content">
		<div class="logo-section">
			<img src="{{ asset('images/logo.png') }}" alt="OsuMap Manager Logo">
		</div>

		<div class="nav-section">
			<nav>
				<ul>
					<li>
						<a href="{{ path('app_accueil') }}">Accueil</a>
					</li>
					<li>
						<a href="{{ path('beatmap_search') }}">Beatmaps</a>
					</li>
					{% if app.user %}
						<li>
							<a href="{{ path('app_profile') }}">Profil</a>
						</li>
						<li>
							<a href="{{ path('app_logout') }}">Déconnexion</a>
						</li>
					{% else %}
						<li>
							<a href="{{ path('app_login') }}">Connexion</a>
						</li>
						<li>
							<a href="{{ path('app_register') }}">S'inscrire</a>
						</li>
					{% endif %}
				</ul>
			</nav>
		</div>
	</div>
</div>
<div class="footer-bottom">
	<p>2026 Osu!Map Manager. Tous droits réservés.</p>
</div></footer></html>
